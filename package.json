{
  "name": "eric-j-portfolio-v2",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:api": "NODE_TLS_REJECT_UNAUTHORIZED=0 npx vercel dev",
    "build": "tsc -b && vite build",
    "lint": "biome lint .",
    "format": "biome format .",
    "preview": "vite preview",
    "type-check": "tsc --noEmit -p tsconfig.app.json",
    "test": "NODE_NO_WARNINGS=1 pnpm run test:default",
    "test:default": "vitest run",
    "test:watch": "NODE_NO_WARNINGS=1 vitest",
    "test:cov": "NODE_NO_WARNINGS=1 vitest run --coverage"
  },
  "dependencies": {
    "@fortawesome/fontawesome-free": "^6.7.2",
    "@hookform/resolvers": "^5.2.2",
    "@sendgrid/mail": "^8.1.6",
    "@tailwindcss/vite": "^4.1.11",
    "embla-carousel-fade": "^8.6.0",
    "embla-carousel-react": "^8.6.0",
    "i18next": "^25.3.0",
    "i18next-browser-languagedetector": "^8.2.0",
    "lucide-react": "^0.575.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-hook-form": "^7.71.2",
    "react-i18next": "^15.5.3",
    "react-player": "^3.4.0",
    "react-router-dom": "^7.6.2",
    "react-toastify": "^11.0.5",
    "tailwindcss": "^4.1.11",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.1.3",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.10.14",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.5.2",
    "@vitest/coverage-v8": "^3.2.4",
    "embla-carousel": "^8.6.0",
    "jsdom": "^26.1.0",
    "typescript": "~5.8.3",
    "vercel": "^50.25.1",
    "vite": "^7.0.0",
    "vite-plugin-svgr": "^4.3.0",
    "vitest": "^3.2.4"
  }
}
